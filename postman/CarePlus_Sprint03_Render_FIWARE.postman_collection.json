    {
      "name": "1. Auth setup",
      "item": [
        {
          "name": "Register test user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function cpfDigit(numbers) {",
                  "  let sum = 0;",
                  "  for (let i = 0; i < numbers.length; i += 1) {",
                  "    sum += Number(numbers[i]) * (numbers.length + 1 - i);",
                  "  }",
                  "  const remainder = (sum * 10) % 11;",
                  "  return remainder === 10 ? 0 : remainder;",
                  "}",
                  "const suffix = Date.now();",
                  "const baseCpf = String(Math.floor(100000000 + Math.random() * 900000000));",
                  "const firstDigit = cpfDigit(baseCpf);",
                  "const secondDigit = cpfDigit(baseCpf + firstDigit);",
                  "pm.collectionVariables.set('postmanEmail', `postman.careplus.${suffix}@example.com`);",
                  "pm.collectionVariables.set('postmanCpf', `${baseCpf}${firstDigit}${secondDigit}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"HTTP status esperado\", function () {",
                  "  pm.expect([200, 201, 204]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code !== 204) {",
                  "  pm.test(\"Resposta em JSON valido\", function () {",
                  "    pm.response.to.be.json;",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{renderBaseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"{{postmanFullName}}\",\n  \"email\": \"{{postmanEmail}}\",\n  \"phone\": \"{{postmanPhone}}\",\n  \"cpf\": \"{{postmanCpf}}\",\n  \"birth_date\": \"{{postmanBirthDate}}\",\n  \"password\": \"{{postmanPassword}}\"\n}"
            }
          }
        },
        {
          "name": "Login test user",
